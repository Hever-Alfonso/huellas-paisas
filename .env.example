# ======================================================================
# Huellas Paisas - Variables de entorno
# Copia este archivo a .env y reemplaza los valores con los tuyos.
# NUNCA subas el archivo .env real al repositorio.
# ======================================================================

# API key de Google Gemini. Consíguela en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Modelo de Gemini a utilizar
GEMINI_MODEL=gemini-2.5-flash

# URL de la base de datos SQLite (ruta relativa al directorio de ejecución)
DATABASE_URL=sqlite:///./data/huellas_paisas.db

# Entorno: development | production
ENVIRONMENT=development
